# Keep the deploy upload small: only ship what the app needs to run.
.git/
.gitignore
.venv/
__pycache__/
*.pyc
.env
.env.example

# The website (frontend/dist/, the built React app) is served BY this same Cloud Run
# service -- see main.py's StaticFiles mount. Only frontend/dist/ itself is needed; the
# source, node_modules, and the old plain-JS web/ folder are not shipped. The browser
# extension stays separate (installed in-browser, not hosted).
extension/
web/
frontend/node_modules/
frontend/src/
frontend/public/
frontend/extension-dist/
frontend/*.md
frontend/*.json
frontend/*.ts
frontend/index.html

# Docs aren't needed to run the server
*.md
