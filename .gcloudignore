# Keep the deploy upload small: only ship what the app needs to run.
.git/
.gitignore
.venv/
__pycache__/
*.pyc
.env
.env.example

# The website (web/) is now served BY this same Cloud Run service -- see main.py's
# StaticFiles mount. Only the extension stays separate (installed in-browser, not hosted).
extension/
web/node_modules/
web/dist/

# Docs aren't needed to run the server
*.md
