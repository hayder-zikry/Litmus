# Gemini runs through VERTEX AI (not the AI Studio API key) so it bills to our Google Cloud
# project and uses the free-trial credits. Auth is via `gcloud auth application-default login`
# (ADC) -- there is NO Gemini API key. Make sure the Vertex AI API (aiplatform.googleapis.com)
# is enabled on the project.
GEMINI_MODEL=gemini-3.6-flash
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# The Fact Check Tools API still uses a plain API key (it's a separate REST API).
FACTCHECK_API_KEY=your-factcheck-api-key

# Used by provenance.py to get reliable upload dates for YouTube-hosted matches (scraping
# YouTube's watch page directly gets served a bot-safe page with no date metadata from
# datacenter IPs like Cloud Run's, so the Data API is used instead).
YOUTUBE_API_KEY=your-youtube-data-api-key

# Shared secret for DELETE /cache (wipes the seeded demo cache). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Pass it back as the X-Admin-Key header. Without this set, the endpoint always rejects.
ADMIN_KEY=your-own-random-secret
