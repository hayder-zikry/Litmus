# Gemini runs through VERTEX AI (not the AI Studio API key) so it bills to our Google Cloud
# project and uses the free-trial credits. Auth is via `gcloud auth application-default login`
# (ADC) -- there is NO Gemini API key. Make sure the Vertex AI API (aiplatform.googleapis.com)
# is enabled on the project.
GEMINI_MODEL=gemini-3.6-flash
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# The Fact Check Tools API still uses a plain API key (it's a separate REST API).
FACTCHECK_API_KEY=your-factcheck-api-key
